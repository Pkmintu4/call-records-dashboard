# Render production environment template for call-records-dashboard
# Do not put real secrets in this file before committing.

APP_ENV=prod
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
CORS_ORIGINS=["https://call-records-dashboard.onrender.com"]

# Google auth (recommended on Render: JSON value, not file path)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_SUBJECT=
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id
GOOGLE_REDIRECT_URI=https://call-records-dashboard.onrender.com/api/google/callback

# Optional OAuth mode (leave empty if using service account)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# AI provider
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# Ingest and transcription
AUTO_INGEST_ENABLED=true
AUTO_INGEST_INTERVAL_SECONDS=300
INGEST_FORCE_AUDIO_ONLY=true
AUDIO_INGEST_ENABLED=true
TRANSCRIPTION_PROVIDER=google_speech
ALLOWED_TRANSCRIPT_LANGUAGES=["en","hi","te"]
GOOGLE_SPEECH_LANGUAGE_CODES=["en-US","hi-IN","te-IN","en-IN"]
GOOGLE_SPEECH_MODEL=phone_call
GOOGLE_SPEECH_USE_ENHANCED=true
TRANSCRIPTION_TIMEOUT_SECONDS=180
TRANSCRIPTION_POLL_INTERVAL_SECONDS=2
TRANSCRIPTION_LONG_RUNNING_THRESHOLD_SECONDS=55
TRANSCRIPTION_NORMALIZE_AUDIO=true
TRANSCRIPTION_MAX_AUDIO_MB=25

# Optional Gemini
GEMINI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_SECONDS=60
GEMINI_TRANSCRIPTION_MODEL=gemini-1.5-flash
GEMINI_TRANSCRIPTION_INLINE_MAX_MB=18
